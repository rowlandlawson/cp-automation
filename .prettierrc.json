{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "overrides": [
    {
      "files": [
        "admin/**/*.js",
        "assets/**/*.js",
        "admin/**/*.css",
        "assets/**/*.css",
        "*.html",
        "admin/**/*.html"
      ],
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": ["backend/**/*.ts", "scripts/**/*.mjs", "*.json", "*.md", "*.yml", "*.yaml"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
