generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Phase 2 target schema: collection models remain recognizable, while
/// singleton page models and media relations make the website fully CMS-driven.

enum MediaAssetType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

enum PageType {
  HOME
  ABOUT
  GLOBAL
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique @db.VarChar(255)
  email               String               @unique @db.VarChar(255)
  passwordHash        String               @map("password_hash") @db.VarChar(255)
  passwordChangedAt   DateTime?            @map("password_changed_at") @db.Timestamp(6)
  role                String               @default("admin") @db.VarChar(50)
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime             @default(now()) @map("updated_at") @db.Timestamp(6)
  passwordResetTokens PasswordResetToken[]
  updatedSections     ContentSection[]     @relation("ContentSectionUpdatedBy")
  uploadedMediaAssets MediaAsset[]         @relation("MediaAssetUploadedBy")

  @@index([isActive], map: "idx_users_is_active")
  @@map("users")
}

model PasswordResetToken {
  id                   Int       @id @default(autoincrement())
  userId               Int       @map("user_id")
  tokenHash            String    @unique @map("token_hash") @db.VarChar(128)
  verificationCodeHash String?   @map("verification_code_hash") @db.VarChar(128)
  expiresAt            DateTime  @map("expires_at") @db.Timestamp(6)
  usedAt               DateTime? @map("used_at") @db.Timestamp(6)
  requestedByIp        String?   @map("requested_by_ip") @db.VarChar(64)
  requestedUserAgent   String?   @map("requested_user_agent") @db.VarChar(255)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_password_reset_tokens_user_created")
  @@index([expiresAt, usedAt], map: "idx_password_reset_tokens_expiry")
  @@index([verificationCodeHash, expiresAt, usedAt], map: "idx_password_reset_tokens_code_expiry")
  @@map("password_reset_tokens")
}

model MediaAsset {
  id                         Int          @id @default(autoincrement())
  title                      String?      @db.VarChar(255)
  altText                    String?      @map("alt_text") @db.VarChar(255)
  fileName                   String?      @map("file_name") @db.VarChar(255)
  url                        String       @db.VarChar(1000)
  secureUrl                  String?      @map("secure_url") @db.VarChar(1000)
  publicId                   String?      @unique @map("public_id") @db.VarChar(255)
  folder                     String?      @db.VarChar(255)
  assetType                  MediaAssetType @default(IMAGE) @map("asset_type")
  mimeType                   String?      @map("mime_type") @db.VarChar(120)
  width                      Int?
  height                     Int?
  bytes                      Int?
  uploadedById               Int?         @map("uploaded_by_id")
  createdAt                  DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                  DateTime     @default(now()) @map("updated_at") @db.Timestamp(6)
  uploadedBy                 User?        @relation("MediaAssetUploadedBy", fields: [uploadedById], references: [id])
  siteSettingsLogoRecords    SiteSettings[] @relation("SiteSettingsLogoAsset")
  siteSettingsOgImageRecords SiteSettings[] @relation("SiteSettingsOgImageAsset")
  homePageHeroAssets         HomePage[]   @relation("HomePageHeroAsset")
  homePageOgImageRecords     HomePage[]   @relation("HomePageOgImageAsset")
  aboutPagePortraitRecords   AboutPage[]  @relation("AboutPagePortraitAsset")
  aboutPageOgImageRecords    AboutPage[]  @relation("AboutPageOgImageAsset")
  pageSectionFeaturedRecords PageSection[] @relation("PageSectionFeaturedAsset")
  projectPrimaryImageRecords Project[]    @relation("ProjectPrimaryImageAsset")
  projectOgImageRecords      Project[]    @relation("ProjectOgImageAsset")
  productFeaturedAssetRecords Product[]   @relation("ProductFeaturedAsset")
  productOgImageRecords      Product[]    @relation("ProductOgImageAsset")
  serviceFeaturedAssetRecords Service[]   @relation("ServiceFeaturedAsset")
  serviceOgImageRecords      Service[]    @relation("ServiceOgImageAsset")

  @@index([assetType, folder], map: "idx_media_assets_type_folder")
  @@index([uploadedById], map: "idx_media_assets_uploaded_by")
  @@map("media_assets")
}

model Project {
  id            Int        @id @default(autoincrement())
  title         String     @db.VarChar(255)
  slug          String?    @unique @db.VarChar(255)
  description   String?    @db.Text
  location      String?    @db.VarChar(255)
  imageUrl      String?    @map("image_url") @db.VarChar(500)
  imagePublicId String?    @map("image_public_id") @db.VarChar(255)
  imageAssetId  Int?       @map("image_asset_id")
  ogImageAssetId Int?      @map("og_image_asset_id")
  metaTitle     String?    @map("meta_title") @db.VarChar(255)
  metaDescription String?  @map("meta_description") @db.VarChar(320)
  orderIndex    Int        @default(0) @map("order_index")
  isPublished   Boolean    @default(true) @map("is_published")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  imageAsset    MediaAsset? @relation("ProjectPrimaryImageAsset", fields: [imageAssetId], references: [id])
  ogImageAsset  MediaAsset? @relation("ProjectOgImageAsset", fields: [ogImageAssetId], references: [id])

  @@index([isPublished, orderIndex, createdAt], map: "idx_projects_published_order")
  @@index([imageAssetId], map: "idx_projects_image_asset")
  @@index([ogImageAssetId], map: "idx_projects_og_image_asset")
  @@map("projects")
}

model Product {
  id              Int        @id @default(autoincrement())
  name            String     @db.VarChar(255)
  slug            String?    @unique @db.VarChar(255)
  description     String?    @db.Text
  features        String?    @db.Text
  featureList     Json?      @map("feature_list")
  ctaLabel        String?    @map("cta_label") @db.VarChar(120)
  ctaUrl          String?    @map("cta_url") @db.VarChar(500)
  featuredAssetId Int?       @map("featured_asset_id")
  ogImageAssetId  Int?       @map("og_image_asset_id")
  metaTitle       String?    @map("meta_title") @db.VarChar(255)
  metaDescription String?    @map("meta_description") @db.VarChar(320)
  orderIndex      Int        @default(0) @map("order_index")
  isPublished     Boolean    @default(true) @map("is_published")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  featuredAsset   MediaAsset? @relation("ProductFeaturedAsset", fields: [featuredAssetId], references: [id])
  ogImageAsset    MediaAsset? @relation("ProductOgImageAsset", fields: [ogImageAssetId], references: [id])

  @@index([isPublished, orderIndex, createdAt], map: "idx_products_published_order")
  @@index([featuredAssetId], map: "idx_products_featured_asset")
  @@index([ogImageAssetId], map: "idx_products_og_image_asset")
  @@map("products")
}

model Service {
  id              Int        @id @default(autoincrement())
  name            String     @db.VarChar(255)
  slug            String?    @unique @db.VarChar(255)
  description     String?    @db.Text
  iconName        String?    @map("icon_name") @db.VarChar(100)
  highlightList   Json?      @map("highlight_list")
  ctaLabel        String?    @map("cta_label") @db.VarChar(120)
  ctaUrl          String?    @map("cta_url") @db.VarChar(500)
  featuredAssetId Int?       @map("featured_asset_id")
  ogImageAssetId  Int?       @map("og_image_asset_id")
  metaTitle       String?    @map("meta_title") @db.VarChar(255)
  metaDescription String?    @map("meta_description") @db.VarChar(320)
  orderIndex      Int        @default(0) @map("order_index")
  isPublished     Boolean    @default(true) @map("is_published")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  featuredAsset   MediaAsset? @relation("ServiceFeaturedAsset", fields: [featuredAssetId], references: [id])
  ogImageAsset    MediaAsset? @relation("ServiceOgImageAsset", fields: [ogImageAssetId], references: [id])

  @@index([isPublished, orderIndex, createdAt], map: "idx_services_published_order")
  @@index([featuredAssetId], map: "idx_services_featured_asset")
  @@index([ogImageAssetId], map: "idx_services_og_image_asset")
  @@map("services")
}

/// Legacy generic content blocks used by the current admin dashboard.
/// Keep this during migration, then retire it after PageSection rolls out.
model ContentSection {
  id          Int      @id @default(autoincrement())
  sectionName String   @unique @map("section_name") @db.VarChar(100)
  content     String?  @db.Text
  updatedBy   Int?     @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  updatedByUser User?  @relation("ContentSectionUpdatedBy", fields: [updatedBy], references: [id])

  @@index([updatedBy], map: "idx_content_sections_updated_by")
  @@map("content_sections")
}

model Testimonial {
  id            Int      @id @default(autoincrement())
  quote         String   @db.Text
  author        String?  @db.VarChar(255)
  authorRole    String?  @map("author_role") @db.VarChar(255)
  companyName   String?  @map("company_name") @db.VarChar(255)
  location      String?  @db.VarChar(255)
  rating        Int      @default(5)
  sourceUrl     String?  @map("source_url") @db.VarChar(500)
  isFeatured    Boolean  @default(true) @map("is_featured")
  orderIndex    Int      @default(0) @map("order_index")
  isPublished   Boolean  @default(true) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([isPublished, isFeatured, orderIndex, createdAt], map: "idx_testimonials_published_featured_order")
  @@map("testimonials")
}

model SiteSettings {
  id                    Int        @id @default(1)
  companyName           String     @map("company_name") @db.VarChar(255)
  siteTagline           String?    @map("site_tagline") @db.VarChar(255)
  companySummary        String?    @map("company_summary") @db.Text
  phone                 String?    @db.VarChar(50)
  whatsappNumber        String?    @map("whatsapp_number") @db.VarChar(50)
  whatsappLink          String?    @map("whatsapp_link") @db.VarChar(500)
  email                 String?    @db.VarChar(255)
  address               String?    @db.VarChar(255)
  socialLinks           Json?      @map("social_links")
  footerMotto           String?    @map("footer_motto") @db.VarChar(255)
  footerTagline         String?    @map("footer_tagline") @db.Text
  footerSummary         String?    @map("footer_summary") @db.Text
  footerQuickLinks      Json?      @map("footer_quick_links")
  footerProductLinks    Json?      @map("footer_product_links")
  logoAssetId           Int?       @map("logo_asset_id")
  defaultOgImageAssetId Int?       @map("default_og_image_asset_id")
  metaTitle             String?    @map("meta_title") @db.VarChar(255)
  metaDescription       String?    @map("meta_description") @db.VarChar(320)
  canonicalBaseUrl      String?    @map("canonical_base_url") @db.VarChar(500)
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  logoAsset             MediaAsset? @relation("SiteSettingsLogoAsset", fields: [logoAssetId], references: [id])
  defaultOgImageAsset   MediaAsset? @relation("SiteSettingsOgImageAsset", fields: [defaultOgImageAssetId], references: [id])

  @@index([logoAssetId], map: "idx_site_settings_logo_asset")
  @@index([defaultOgImageAssetId], map: "idx_site_settings_og_image_asset")
  @@map("site_settings")
}

model HomePage {
  id                              Int        @id @default(1)
  slug                            String     @unique @default("home") @db.VarChar(100)
  isPublished                     Boolean    @default(true) @map("is_published")
  heroEyebrow                     String?    @map("hero_eyebrow") @db.VarChar(120)
  heroHeading                     String     @map("hero_heading") @db.VarChar(255)
  heroSubheading                  String?    @map("hero_subheading") @db.Text
  heroPrimaryCtaLabel             String?    @map("hero_primary_cta_label") @db.VarChar(120)
  heroPrimaryCtaUrl               String?    @map("hero_primary_cta_url") @db.VarChar(500)
  heroSecondaryCtaLabel           String?    @map("hero_secondary_cta_label") @db.VarChar(120)
  heroSecondaryCtaUrl             String?    @map("hero_secondary_cta_url") @db.VarChar(500)
  heroStats                       Json?      @map("hero_stats")
  heroVisualAssetId               Int?       @map("hero_visual_asset_id")
  aboutSummaryTitle               String?    @map("about_summary_title") @db.VarChar(255)
  aboutSummarySubtitle            String?    @map("about_summary_subtitle") @db.Text
  aboutSummaryCtaLabel            String?    @map("about_summary_cta_label") @db.VarChar(120)
  aboutSummaryCtaUrl              String?    @map("about_summary_cta_url") @db.VarChar(500)
  aboutMissionTitle               String?    @map("about_mission_title") @db.VarChar(255)
  aboutMissionBody                String?    @map("about_mission_body") @db.Text
  aboutWhyChooseTitle             String?    @map("about_why_choose_title") @db.VarChar(255)
  aboutWhyChoosePoints            Json?      @map("about_why_choose_points")
  productsSectionTitle            String?    @map("products_section_title") @db.VarChar(255)
  productsSectionIntro            String?    @map("products_section_intro") @db.Text
  servicesSectionTitle            String?    @map("services_section_title") @db.VarChar(255)
  servicesSectionIntro            String?    @map("services_section_intro") @db.Text
  projectsSectionTitle            String?    @map("projects_section_title") @db.VarChar(255)
  projectsSectionIntro            String?    @map("projects_section_intro") @db.Text
  testimonialsSectionTitle        String?    @map("testimonials_section_title") @db.VarChar(255)
  testimonialsSectionIntro        String?    @map("testimonials_section_intro") @db.Text
  customSolutionsTitle            String?    @map("custom_solutions_title") @db.VarChar(255)
  customSolutionsSubtitle         String?    @map("custom_solutions_subtitle") @db.Text
  customSolutionsDevelopmentTitle String?    @map("custom_solutions_development_title") @db.VarChar(255)
  customSolutionsDevelopmentBody  String?    @map("custom_solutions_development_body") @db.Text
  customSolutionsFeatures         Json?      @map("custom_solutions_features")
  customSolutionsProcessTitle     String?    @map("custom_solutions_process_title") @db.VarChar(255)
  customSolutionsProcessSteps     Json?      @map("custom_solutions_process_steps")
  customSolutionsCtaLabel         String?    @map("custom_solutions_cta_label") @db.VarChar(120)
  customSolutionsCtaUrl           String?    @map("custom_solutions_cta_url") @db.VarChar(500)
  contactCtaTitle                 String?    @map("contact_cta_title") @db.VarChar(255)
  contactCtaBody                  String?    @map("contact_cta_body") @db.Text
  contactCtaActions               Json?      @map("contact_cta_actions")
  metaTitle                       String?    @map("meta_title") @db.VarChar(255)
  metaDescription                 String?    @map("meta_description") @db.VarChar(320)
  ogImageAssetId                  Int?       @map("og_image_asset_id")
  createdAt                       DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                       DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  heroVisualAsset                 MediaAsset? @relation("HomePageHeroAsset", fields: [heroVisualAssetId], references: [id])
  ogImageAsset                    MediaAsset? @relation("HomePageOgImageAsset", fields: [ogImageAssetId], references: [id])

  @@index([isPublished], map: "idx_home_pages_published")
  @@index([heroVisualAssetId], map: "idx_home_pages_hero_asset")
  @@index([ogImageAssetId], map: "idx_home_pages_og_image_asset")
  @@map("home_pages")
}

model AboutPage {
  id                 Int        @id @default(1)
  slug               String     @unique @default("about") @db.VarChar(100)
  isPublished        Boolean    @default(true) @map("is_published")
  pageTitle          String?    @map("page_title") @db.VarChar(255)
  pageSubtitle       String?    @map("page_subtitle") @db.Text
  founderName        String     @map("founder_name") @db.VarChar(255)
  founderRole        String?    @map("founder_role") @db.VarChar(255)
  portraitAssetId    Int?       @map("portrait_asset_id")
  shortBio           String?    @map("short_bio") @db.Text
  longStory          String?    @map("long_story") @db.Text
  mission            String?    @db.Text
  vision             String?    @db.Text
  values             Json?
  certifications     Json?
  yearsOfExperience  Int?       @map("years_of_experience")
  stats              Json?
  serviceLocations   Json?      @map("service_locations")
  credibilityPoints  Json?      @map("credibility_points")
  primaryCtaLabel    String?    @map("primary_cta_label") @db.VarChar(120)
  primaryCtaUrl      String?    @map("primary_cta_url") @db.VarChar(500)
  metaTitle          String?    @map("meta_title") @db.VarChar(255)
  metaDescription    String?    @map("meta_description") @db.VarChar(320)
  ogImageAssetId     Int?       @map("og_image_asset_id")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  portraitAsset      MediaAsset? @relation("AboutPagePortraitAsset", fields: [portraitAssetId], references: [id])
  ogImageAsset       MediaAsset? @relation("AboutPageOgImageAsset", fields: [ogImageAssetId], references: [id])

  @@index([isPublished], map: "idx_about_pages_published")
  @@index([portraitAssetId], map: "idx_about_pages_portrait_asset")
  @@index([ogImageAssetId], map: "idx_about_pages_og_image_asset")
  @@map("about_pages")
}

model PageSection {
  id              Int        @id @default(autoincrement())
  pageType        PageType   @map("page_type")
  sectionKey      String     @map("section_key") @db.VarChar(100)
  title           String?    @db.VarChar(255)
  subtitle        String?    @db.Text
  body            String?    @db.Text
  content         Json?
  ctaLabel        String?    @map("cta_label") @db.VarChar(120)
  ctaUrl          String?    @map("cta_url") @db.VarChar(500)
  featuredAssetId Int?       @map("featured_asset_id")
  orderIndex      Int        @default(0) @map("order_index")
  isPublished     Boolean    @default(true) @map("is_published")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  featuredAsset   MediaAsset? @relation("PageSectionFeaturedAsset", fields: [featuredAssetId], references: [id])

  @@unique([pageType, sectionKey], map: "page_sections_page_type_section_key_key")
  @@index([pageType, isPublished, orderIndex], map: "idx_page_sections_page_type_published_order")
  @@index([featuredAssetId], map: "idx_page_sections_featured_asset")
  @@map("page_sections")
}
