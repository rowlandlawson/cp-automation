# Required infrastructure
DATABASE_URL=postgresql://production_user:production_password@host:5432/cp_automation_production
PORT=10000
CORS_ORIGIN=https://cpautomation.com
ADMIN_APP_URL=https://cpautomation.com/admin
JWT_SECRET=replace_with_a_long_random_production_secret
NODE_ENV=production

# Cloudinary media storage
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Password reset delivery
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Recommended: direct transactional email through Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@cpautomation.com
BREVO_SENDER_NAME=CP Automation
BREVO_REPLY_TO_EMAIL=
BREVO_REPLY_TO_NAME=

# Optional alternative/fallback: custom webhook receiver
PASSWORD_RESET_WEBHOOK_URL=

# Admin seed input used to create/update the database admin account
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cpautomation.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_ROLE=admin

# Optional smoke-test overrides
SMOKE_API_BASE_URL=https://your-production-backend.onrender.com/api
SMOKE_ADMIN_USERNAME=
SMOKE_ADMIN_PASSWORD=
