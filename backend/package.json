{
  "name": "cp-automation-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "bun run prisma:generate",
    "dev": "bun --watch index.ts",
    "dev:nodemon": "nodemon --watch . --ext ts --exec bun run index.ts",
    "start": "bun run index.ts",
    "check": "tsc --noEmit",
    "db:check": "bun run scripts/check-db.ts",
    "db:apply-schema": "bun run scripts/apply-schema.ts",
    "db:check:prisma": "bun run scripts/check-prisma.ts",
    "db:migrate:phase3": "bunx --bun prisma db execute --file prisma/migrations/202604030001_phase3_cms_redesign/migration.sql",
    "db:import:legacy": "bun run scripts/import-legacy-to-prisma.ts",
    "db:seed": "bunx --bun prisma db seed",
    "db:seed:all": "bun run prisma/seed.ts --scope all",
    "db:seed:admin": "bun run prisma/seed.ts --scope admin",
    "db:seed:media": "bun run prisma/seed.ts --scope media",
    "db:seed:site-settings": "bun run prisma/seed.ts --scope site-settings",
    "db:seed:home-page": "bun run prisma/seed.ts --scope home-page",
    "db:seed:about-page": "bun run prisma/seed.ts --scope about-page",
    "db:seed:products": "bun run prisma/seed.ts --scope products",
    "db:seed:services": "bun run prisma/seed.ts --scope services",
    "db:seed:projects": "bun run prisma/seed.ts --scope projects",
    "db:seed:testimonials": "bun run prisma/seed.ts --scope testimonials",
    "db:seed:page-sections": "bun run prisma/seed.ts --scope page-sections",
    "db:seed:content-sections": "bun run prisma/seed.ts --scope content-sections",
    "db:seed:foundation": "bun run prisma/seed.ts --scope site-settings --scope home-page --scope about-page",
    "db:seed:catalog": "bun run prisma/seed.ts --scope products --scope services --scope projects --scope testimonials",
    "db:seed:content": "bun run prisma/seed.ts --scope page-sections --scope content-sections",
    "db:verify:migration": "bun run scripts/verify-prisma-migration.ts",
    "db:verify:seed": "bun run scripts/verify-seed-readiness.ts",
    "db:verify:scopes": "bun run scripts/verify-seed-scopes.ts",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:validate": "bunx --bun prisma validate",
    "prisma:migrate:dev": "bunx --bun prisma migrate dev",
    "prisma:migrate:deploy": "bunx --bun prisma migrate deploy",
    "prisma:studio": "bunx --bun prisma studio",
    "admin:create": "bun run scripts/create-admin.ts",
    "smoke:api": "bun run scripts/smoke-api.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "sharp": "^0.34.5"
  }
}
